{
    "theme": {
        "aside": {
            "border-radius": "6px",
            "border-style": "double",
            "border-width": "3px"
        },
        "border-radius": "0",
        "button": {
            "border-radius": "16px",
            "border-width": "1px",
            "border-style": "solid"
        },
        "code": {
            "border-radius": "16px",
            "border-width": "1px",
            "border-style": "solid"
        },
        "color": {
            "fill": {
                "dark": "rgb(20, 20, 22)",
                "light": "rgb(255, 255, 255)"
            },
            "dim-purple": "#392048",
            "standard-purple-documentation-intro-fill": "var(--color-documentation-intro-fill)",
            "documentation-intro-fill": "radial-gradient(circle at top, var(--color-dim-purple) 30%, #1f1d1f 100%)",
            "documentation-intro-accent": "var(--color-dim-purple)"
        },
        "icons": {
            "technology": "/images/technology.svg",
            "article": "/images/article.svg"
        },
        "typography": {
            "html-font": ""
        }
    },
    "features": {
        "quickNavigation": {
            "enable": true
        }
    }
}
